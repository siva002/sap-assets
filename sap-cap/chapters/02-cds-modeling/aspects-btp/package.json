{
  "name": "aspects-btp",
  "version": "1.0.0",
  "description": "Sales Order Management — CAP with aspects and reuse types, deployed to BTP Cloud Foundry with PostgreSQL",
  "scripts": {
    "start": "npx cds serve",
    "dev": "cds watch",
    "deploy": "cds deploy"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@cap-js/postgres": "^1",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8"
  },
  "cds": {
    "requires": {
      "db": "postgres",
      "auth": "dummy"
    },
    "[development]": {
      "requires": {
        "db": "postgres",
        "auth": "dummy"
      }
    }
  }
}
