meta {
  name: Top 5 by amount descending
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/Orders?$orderby=totalAmount desc&$top=5&$select=orderNumber,status,totalAmount
  body: none
  auth: basic
}

auth:basic {
  username: {{salesRepUser}}
  password: password
}

headers {
  Accept: application/json
}
