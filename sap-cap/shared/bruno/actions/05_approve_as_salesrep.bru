meta {
  name: Approve as SalesRep → 403
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/Orders(ID={{submittedOrderId}},IsActiveEntity=true)/OrderService.approve
  body: none
  auth: basic
}

auth:basic {
  username: {{salesRepUser}}
  password: password
}

headers {
  Accept: application/json
}
